{
  "name": "avathar/bbguild-wow",
  "type": "phpbb-extension",
  "description": "World of Warcraft game plugin for bbGuild. Provides WoW classes, races, factions, and Battle.net API integration.",
  "homepage": "https://github.com/avatharbe/bbguild-wow",
  "version": "2.0.0-b2",
  "time": "2026-03-15",
  "license": "GPL-2.0-only",
  "authors": [
    {
      "name": "Andreas Vandenberghe (Sajaki)",
      "email": "sajaki@avathar.be",
      "homepage": "https://www.avathar.be",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=8.1",
    "composer/installers": "~1.0"
  },
  "extra": {
    "display-name": "bbGuild - World of Warcraft",
    "soft-require": {
      "phpbb/phpbb": ">=3.3.0,<3.4.0@dev",
      "avathar/bbguild": ">=2.0.0-a10"
    },
    "version-check": {
      "host": "www.avathar.be",
      "directory": "/versioncheck",
      "filename": "bbguild-wow.json",
      "ssl": true
    }
  }
}
